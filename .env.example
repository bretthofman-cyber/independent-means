# ── Supabase ──────────────────────────────────────────────────────────────────
# Public anon key — safe to expose in the client bundle (VITE_ prefix required).
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Service-role key — server-side only. NEVER add a VITE_ prefix.
# Used by Vercel API functions to bypass RLS when writing subscription records.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Secret key — server-side only. NEVER add a VITE_ prefix.
# Use sk_test_... for test mode, sk_live_... for production.
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from the Stripe dashboard (Developers → Webhooks → your endpoint).
# Used to verify the STRIPE-SIGNATURE header on incoming webhook events.
# NEVER add a VITE_ prefix.
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs for the two subscription plans — server-side only.
# Copy these from Stripe dashboard (Products → your product → Pricing).
# Use price_test_... IDs in test mode; swap to price_live_... for production.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Server-side only. NEVER add a VITE_ prefix.
ANTHROPIC_API_KEY=sk-ant-...

# ── Admin analytics dashboard ─────────────────────────────────────────────────
# Server-side: email address allowed to access /api/admin-stats.
ADMIN_EMAIL=you@example.com

# Client-side: same email, exposed to the browser only to show/hide the Analytics button.
# Must match ADMIN_EMAIL exactly.
VITE_ADMIN_EMAIL=you@example.com
